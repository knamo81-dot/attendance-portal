:root {
  --page-padding: var(--common-page-padding, 14px);

  --card-padding: var(--common-card-padding, 12px);
  --card-radius: var(--common-card-radius, 14px);
  --card-gap: 8px;

  --control-height: var(--common-control-height, 28px);
  --control-radius: var(--common-control-radius, 8px);

  --font-title: 13px;
  --font-base: var(--common-font-size-base, 11px);
  --font-small: var(--common-font-size-small, 10px);

  --gap-xs: 3px;
  --gap-sm: 5px;
  --gap-md: 8px;

  --shadow-card: var(--common-shadow-card, 0 5px 14px rgba(15, 23, 42, 0.045));

  --module-bg: var(--common-bg, #f1f5f9);
  --module-card: var(--common-card, #ffffff);
  --module-line: var(--common-line, #e2e8f0);
  --module-text: var(--common-text, #0f172a);
  --module-muted: var(--common-muted, #64748b);

  /* 업무 홈 고유 색상 유지 */
  --module-dark: #0f172a;
  --module-accent: var(--current-header-accent, #0ea5e9);
}

/* =========================================================
   Common theme token link
   - common/theme.css의 --common-* 값을 사용하도록 연결
   - 업무 홈 고유 accent/header 색상은 유지
   - fallback 값을 함께 넣어 common 파일 누락 시에도 기존 화면 유지
========================================================= */

/* ExeloLab Common Compact UI - prefix only */
.page.el-page {
  padding: var(--page-padding) var(--page-padding) var(--page-padding) 0;
}

.card.el-card {
  padding: var(--card-padding);
  border-radius: var(--card-radius);
  box-shadow: var(--shadow-card);
}

.card.el-card h2,
.el-title {
  font-size: var(--font-title);
  margin-bottom: 6px;
}

.card.el-card p,
.el-text {
  font-size: var(--font-base);
  line-height: 1.45;
}

.input.el-input,
.select.el-select {
  height: var(--control-height);
  border-radius: var(--control-radius);
  font-size: var(--font-base);
  padding: 0 8px;
}

.btn.el-btn,
.btn.el-btn.primary,
.btn.el-btn.danger,
.btn.el-btn.soft {
  height: var(--control-height);
  min-height: var(--control-height);
  border-radius: var(--control-radius);
  padding: 0 8px;
  font-size: var(--font-base);
  font-weight: 700;
}

.btn.el-btn-primary {
  background: #0f172a;
  color: #fff;
  border-color: #0f172a;
}

.btn.el-btn-danger {
  color: #dc2626;
  border-color: #fecaca;
  background: #fff;
}

.btn.el-btn-soft {
  background: #f8fafc;
  color: #334155;
}

.badge.el-badge {
  height: 18px;
  padding: 0 6px;
  font-size: var(--font-small);
}

/* iframe module base */
.module-root {
  width: 100%;
  height: 100vh;
  padding: var(--page-padding);
  overflow: hidden;
  background: var(--module-bg);
  color: var(--module-text);
}

.module-frame {
  width: 100%;
  height: 100%;
  min-height: 0;
  background: var(--module-card);
  border: 1px solid var(--module-line);
  border-radius: var(--card-radius);
  box-shadow: var(--shadow-card);
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.module-frame-header {
  flex: 0 0 auto;
  min-height: 44px;
  padding: 0 var(--card-padding);
  border-bottom: 1px solid var(--module-line);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--gap-md);
}

.module-frame-body {
  flex: 1 1 auto;
  min-height: 0;
  padding: var(--card-padding);
  overflow-y: auto;
  overflow-x: hidden;
}

.module-btn {
  height: var(--control-height);
  border-radius: var(--control-radius);
  border: 1px solid #cbd5e1;
  background: #ffffff;
  color: #334155;
  font-size: var(--font-base);
  font-weight: 800;
  padding: 0 10px;
  cursor: pointer;
  white-space: nowrap;
}

.module-btn.primary {
  border-color: var(--module-dark);
  background: var(--module-dark);
  color: #ffffff;
}

.module-input,
.module-select {
  height: var(--control-height);
  border-radius: var(--control-radius);
  border: 1px solid #cbd5e1;
  background: #ffffff;
  color: #334155;
  font-size: var(--font-base);
  padding: 0 9px;
  outline: none;
}

.module-input:focus,
.module-select:focus {
  border-color: var(--module-accent);
  box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.10);
}

/* =========================================================
   Step 3-1 Common Button Shape Link: work-home common-ui
   - 업무 홈/모듈 버튼 색상은 기존 스타일 유지
   - 높이/반경/패딩/폰트/정렬만 공통 토큰과 연결
   - 기능/JS 변경 없음
========================================================= */
.btn.el-btn,
.btn.el-btn.primary,
.btn.el-btn.danger,
.btn.el-btn.soft,
.module-btn,
.badge.el-badge {
  min-height: var(--common-control-height, var(--control-height, 28px));
  border-radius: var(--common-control-radius, var(--control-radius, 8px));
  font-size: var(--font-base);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  line-height: 1;
  white-space: nowrap;
}

.btn.el-btn,
.btn.el-btn.primary,
.btn.el-btn.danger,
.btn.el-btn.soft,
.module-btn {
  height: var(--common-control-height, var(--control-height, 28px));
  padding: 0 var(--common-control-padding-x, 10px);
  font-weight: 800;
}

.badge.el-badge {
  height: calc(var(--common-control-height, var(--control-height, 28px)) - 8px);
  min-height: calc(var(--common-control-height, var(--control-height, 28px)) - 8px);
  padding: 0 7px;
  font-size: var(--font-small);
}

.module-frame-header .module-btn {
  flex: 0 0 auto;
}

@media (max-width: 1100px) {
  :root {
    --page-padding: 10px;
    --card-padding: 10px;
    --card-gap: 6px;
    --control-height: 26px;
    --font-title: 12px;
    --font-base: 10.5px;
    --font-small: 9.5px;
  }
}

/* =========================================================
   Step 3-2 Common Card Surface Link: work-home common-ui
   - 모듈 프레임/공통 카드 높이와 레이아웃은 유지
   - 겉모양(radius, shadow, border, background)만 공통 토큰과 연결
   - 기능/JS 변경 없음
========================================================= */
.card.el-card,
.module-frame {
  background-color: var(--common-card, var(--module-card, #ffffff));
  border-color: var(--common-line, var(--module-line, #e2e8f0));
  border-radius: var(--common-card-radius, var(--card-radius, 14px));
  box-shadow: var(--common-shadow-card, var(--shadow-card, 0 5px 14px rgba(15, 23, 42, 0.045)));
}

.module-frame-header {
  border-bottom-color: var(--common-line, var(--module-line, #e2e8f0));
}

.module-frame-body {
  background-color: var(--common-card, var(--module-card, #ffffff));
}

.module-input,
.module-select,
.module-btn,
.btn.el-btn,
.badge.el-badge {
  border-color: var(--common-line, #cbd5e1);
}

.module-input,
.module-select {
  border-radius: var(--common-control-radius, var(--control-radius, 8px));
  background-color: var(--common-card, #ffffff);
}

/* =========================================================
   Step 3-3 Common Input Shape Link: work-home common-ui
   - 모듈 input/select의 폭/레이아웃은 유지
   - 높이/반경/폰트/테두리/포커스만 공통 토큰과 연결
   - 기능/JS 변경 없음
========================================================= */
.input.el-input,
.select.el-select,
.module-input,
.module-select {
  min-height: var(--common-control-height, var(--control-height, 28px));
  height: var(--common-control-height, var(--control-height, 28px));
  border-radius: var(--common-control-radius, var(--control-radius, 8px));
  border-color: var(--common-line, var(--module-line, #cbd5e1));
  background-color: var(--common-card, #ffffff);
  color: var(--common-text, var(--module-text, #0f172a));
  font-size: var(--font-base);
  outline: none;
}

.input.el-input:focus,
.select.el-select:focus,
.module-input:focus,
.module-select:focus {
  border-color: var(--common-focus, var(--module-accent, #0ea5e9));
  box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.10);
}

/* 브라우저 기본 체크박스/라디오는 공통 높이 강제 제외 */
input[type="checkbox"],
input[type="radio"] {
  min-height: auto !important;
  height: auto !important;
  width: auto !important;
  box-shadow: none !important;
}

/* 파일 입력은 기본 동작을 유지 */
input[type="file"] {
  height: auto !important;
  min-height: var(--common-control-height, var(--control-height, 28px));
}

/* =========================================================
   Step 3-4-1/2 Common Table Surface + Density Link: work-home common-ui
   - 공통 모듈 내부 table의 구조/폭/overflow는 유지
   - 선/헤더/본문색 + padding/font/line-height만 공통화
   - 기능/JS 변경 없음
========================================================= */
.module-frame table,
.card.el-card table {
  width: 100%;
  border-collapse: collapse;
  color: var(--common-text, var(--module-text, #0f172a));
}

.module-frame th,
.module-frame td,
.card.el-card th,
.card.el-card td {
  border-color: var(--common-line, var(--module-line, #e2e8f0));
  padding: 7px 8px;
  font-size: var(--font-base, 11px);
  line-height: 1.35;
}

.module-frame th,
.card.el-card th {
  background-color: var(--common-table-head-bg, #f8fafc);
  color: var(--common-muted, var(--module-muted, #64748b));
  font-weight: 800;
}

.module-frame td,
.card.el-card td {
  color: var(--common-text, var(--module-text, #0f172a));
}

.module-frame .table-wrap,
.card.el-card .table-wrap {
  border-color: var(--common-line, var(--module-line, #e2e8f0));
  background-color: var(--common-card, var(--module-card, #ffffff));
}

